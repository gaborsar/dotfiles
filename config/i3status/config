order += "disk /home"
order += "ethernet _first_"
order += "wireless _first_"
order += "battery all"
order += "volume master"
order += "tztime local"

disk "/home" {
        format = "Home: %avail"
}

ethernet _first_ {
        format_up = "Ethnernet: %speed"
        format_down = "Ethernet: down"
}

wireless _first_ {
        format_up = "Wireless:%quality"
        format_down = "Wireless: down"
}

battery all {
        status_chr = "Charging"
        status_bat = "Battery"
        status_unk = "Unknown"
        status_full = "Full"
        format = "%status: %percentage"
        hide_seconds = true
}

volume master {
        format = "Volume: %volume"
        format_muted = "Volume (muted): %volume"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}

tztime local {
        format = "%d %b %H:%M"
}
